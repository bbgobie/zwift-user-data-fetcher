ZWIFT_USERNAME=your_email@example.com
ZWIFT_PASSWORD=your_password
# Option A: Provide a serialized tough-cookie JSON (single-line) OR a raw phpbb session value
# Examples:
#  - Serialized jar (recommended): set ZWIFTPOWER_COOKIES to the entire JSON string
#  - Raw session value: set ZWIFTPOWER_COOKIES to the phpbb3_lswlk_sid value only
ZWIFTPOWER_COOKIES=

# Option B: Or point to a cookie file (relative to this folder)
ZWIFTPOWER_COOKIE_FILE=zwiftpower_cookies.json

# Notes:
# - If you provide neither, the script will attempt unauthenticated ZwiftPower requests and may receive a login page instead of data.
# - Keep real credentials and cookies out of source control.